<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BCATracker.UI.App"
             RequestedThemeVariant="Dark">

    <!--
        Resources (palette + typography tokens) are loaded via ResourceInclude
        into Application.Resources so they're visible app-wide. They MUST be
        loaded before any Styles file references them via DynamicResource.

        Note that across-file resource references in Avalonia must use
        DynamicResource (not StaticResource) — at load time each StyleInclude
        is parsed independently and StaticResource lookups won't see resources
        defined in sibling files.
    -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://BCA-Tracker/Themes/Palette.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <!-- SimpleTheme provides ScrollBar / Thumb / Popup internals so we
             don't have to write those from scratch. We override every visible
             control style after this. -->
        <SimpleTheme/>

        <StyleInclude Source="avares://BCA-Tracker/Themes/Typography.axaml"/>
        <StyleInclude Source="avares://BCA-Tracker/Themes/Controls.axaml"/>
        <StyleInclude Source="avares://BCA-Tracker/Themes/Cards.axaml"/>
    </Application.Styles>
</Application>
