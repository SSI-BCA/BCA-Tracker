<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BCATracker.UI.Views.LiveMatchPage">

    <Grid RowDefinitions="Auto,Auto,*" Margin="32,24,32,24">

        <!-- ═════ HEADER STRIP ═════════════════════════════════════════════ -->
        <Border Grid.Row="0" Classes="card" Padding="20,16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">

                <!-- Status indicator (live dot) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="LiveDot" Width="10" Height="10"
                             Fill="{DynamicResource Fg.Disabled}"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusLabel"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Classes="label"
                               Text="DISCONNECTED"/>
                </StackPanel>

                <!-- Map / mode -->
                <StackPanel Grid.Column="1" Margin="32,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="MapText"  Classes="section-title" Text="—"/>
                    <TextBlock x:Name="ModeText" Classes="label" Margin="0,2,0,0" Text="—"/>
                </StackPanel>

                <!-- Match timer -->
                <StackPanel Grid.Column="2" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Classes="label" Text="MATCH TIME" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TimerText"
                               Classes="stat-mid"
                               FontSize="22"
                               HorizontalAlignment="Right"
                               Text="—"/>
                </StackPanel>

                <!-- Lives left, Team A -->
                <StackPanel Grid.Column="3" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Classes="label" Text="MY LIVES" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="MyLivesText"
                               Classes="stat-mid good"
                               FontSize="22"
                               HorizontalAlignment="Right"
                               Text="—"/>
                </StackPanel>

                <!-- Lives left, Team B -->
                <StackPanel Grid.Column="4" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Classes="label" Text="ENEMY LIVES" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="EnemyLivesText"
                               Classes="stat-mid danger"
                               FontSize="22"
                               HorizontalAlignment="Right"
                               Text="—"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════ POST-MATCH BANNER (collapsible) ═════════════════════════ -->
        <Border x:Name="PostMatchBanner"
                Grid.Row="1"
                Classes="card"
                Padding="20,14"
                Margin="0,0,0,12"
                IsVisible="False">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock x:Name="OutcomeText"
                           Grid.Column="0"
                           FontFamily="{DynamicResource Font.Display}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="OutcomeSubText" Classes="muted" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Classes="label" Text="YOUR FINAL K/D/A" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="FinalKdaText"
                               Classes="stat-mid"
                               FontSize="20"
                               HorizontalAlignment="Right"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Classes="label" Text="DAMAGE" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="FinalDamageText"
                               Classes="stat-mid"
                               FontSize="20"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════ MAIN AREA ═════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,360">

            <!-- Scoreboard -->
            <Border Grid.Column="0" Classes="card" Padding="0" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Border.Subtle}"
                            BorderThickness="0,0,0,1"
                            Padding="20,14">
                        <TextBlock Classes="section-title" Text="SCOREBOARD"/>
                    </Border>

                    <!-- Column header strip. Column widths must match
                         BuildPlayerRow's grid in LiveMatchPage.axaml.cs:
                         4, *, 1, 110, 1, 80, 1, 80, 1, * -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="4,*,1,110,1,80,1,80,1,*"
                          Margin="20,8,20,8">
                        <TextBlock Grid.Column="1" Classes="label" Text="PLAYER"
                                   Margin="12,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Classes="label" Text="K / D / A"
                                   Margin="0,0,16,0" VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Classes="label" Text="DAMAGE"
                                   Margin="0,0,16,0" VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="7" Classes="label" Text="ACC."
                                   Margin="0,0,16,0" VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="9" Classes="label" Text="LOADOUT"
                                   Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ScoreboardHost" Margin="20,4,20,12"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Kill feed -->
            <Border Grid.Column="1" Classes="card" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Border.Subtle}"
                            BorderThickness="0,0,0,1"
                            Padding="20,14">
                        <TextBlock Classes="section-title" Text="KILL FEED"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="KillFeedHost" Margin="16,8,16,8"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
