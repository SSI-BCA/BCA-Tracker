<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BCATracker.UI.Views.LoadoutsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,0,32,32" MaxWidth="1280" HorizontalAlignment="Stretch">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="PageTitleText" Classes="page-title" Text="Loadouts"/>
                    <TextBlock x:Name="SubtitleText" Classes="muted" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Classes="label" Text="MIN SAMPLES" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button x:Name="MinSamples1Btn" Content="1" Click="MinSamples_Click" Tag="1" Margin="0,0,4,0"/>
                    <Button x:Name="MinSamples3Btn" Content="3" Click="MinSamples_Click" Tag="3" Margin="0,0,4,0"/>
                    <Button x:Name="MinSamples5Btn" Content="5" Click="MinSamples_Click" Tag="5" Margin="0,0,4,0"/>
                    <Button x:Name="MinSamples10Btn" Content="10" Click="MinSamples_Click" Tag="10"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="EmptyHintText"
                       Classes="muted"
                       Text="No matches saved yet. Loadout breakdowns will appear here once you've played a few."
                       IsVisible="False"
                       Margin="0,16,0,16"/>

            <ItemsControl x:Name="LoadoutsHost" Margin="0,16,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
