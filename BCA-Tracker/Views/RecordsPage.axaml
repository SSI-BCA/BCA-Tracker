<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BCATracker.UI.Views.RecordsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,0,32,32" MaxWidth="1280" HorizontalAlignment="Stretch">
            <TextBlock x:Name="PageTitleText" Classes="page-title" Text="Records"/>
            <TextBlock x:Name="SubtitleText" Classes="muted" Margin="0,4,0,24"/>

            <TextBlock x:Name="EmptyHintText"
                       Classes="muted"
                       Text="No matches saved yet. Personal records will appear here once you've played a few."
                       IsVisible="False"
                       Margin="0,0,0,16"/>

            <ItemsControl x:Name="RecordsHost" Margin="-12,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="12"/>
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
