<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:BCATracker.UI.Controls"
             x:Class="BCATracker.UI.Views.HomePage">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="1280" HorizontalAlignment="Stretch">

            <!-- ═════════════════════════════════════════════════════════════
                 IDENTITY + HERO ROW + STAT STRIP
                 Two columns: PFP card on the left, then a stack on the
                 right that contains the 3 hero tiles AND the stat strip.
                 The outer Grid auto-matches column heights, so the PFP
                 card grows to fill the height of (hero row + strip),
                 keeping the avatar comfortably big.
                 ═════════════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="320,*" Margin="0,0,0,16">

                <!-- Identity card — left column. With the right column
                     now being taller (hero row + strip stacked), this
                     card stretches to match, giving the avatar more
                     vertical space. -->
                <Border Grid.Column="0" Classes="card hero-tile" Margin="0,0,12,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <!-- Bigger avatar — 128px. -->
                        <Panel Width="128" Height="128" HorizontalAlignment="Center">
                            <Border x:Name="AvatarFallback"
                                    CornerRadius="64"
                                    Background="{DynamicResource Accent.Gradient}">
                                <TextBlock x:Name="AvatarInitial"
                                           Foreground="#FFFFFF"
                                           FontFamily="{DynamicResource Font.Display}"
                                           FontSize="56"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Border x:Name="AvatarImageHost"
                                    CornerRadius="64"
                                    ClipToBounds="True"
                                    IsVisible="False">
                                <Image x:Name="AvatarImage"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </Panel>

                        <TextBlock x:Name="HandleText"
                                   Margin="0,14,0,2"
                                   HorizontalAlignment="Center"
                                   FontFamily="{DynamicResource Font.Display}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Fg.Primary}"/>
                        <TextBlock x:Name="MatchCountText"
                                   Classes="label"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Right column — hero row stacked over stat strip -->
                <Grid Grid.Column="1" RowDefinitions="*,Auto">

                    <!-- 3 hero tiles -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,*,*" Margin="0,0,0,12">

                        <Border Grid.Column="0" Classes="card hero-tile" Margin="0,0,8,0">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Row="0" Classes="label" Text="K/D RATIO"/>
                                <TextBlock Grid.Row="1" x:Name="HeroKdText"
                                           Classes="stat-value"
                                           FontSize="36"
                                           VerticalAlignment="Center"
                                           TextTrimming="None"/>
                                <TextBlock Grid.Row="2" x:Name="HeroKdaSubtext"
                                           Classes="muted" FontSize="11"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Classes="card hero-tile" Margin="4,0,4,0">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Row="0" Classes="label" Text="WIN RATE"/>
                                <TextBlock Grid.Row="1" x:Name="HeroWinPctText"
                                           Classes="stat-value good"
                                           FontSize="36"
                                           VerticalAlignment="Center"
                                           TextTrimming="None"/>
                                <TextBlock Grid.Row="2" x:Name="HeroWinPctSubtext"
                                           Classes="muted" FontSize="11"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Classes="card hero-tile" Margin="8,0,0,0">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Row="0" Classes="label" Text="MATCHES PLAYED"/>
                                <TextBlock Grid.Row="1" x:Name="HeroMatchesText"
                                           Classes="stat-value"
                                           FontSize="36"
                                           VerticalAlignment="Center"
                                           TextTrimming="None"/>
                                <TextBlock Grid.Row="2" x:Name="HeroPlayTimeText"
                                           Classes="muted" FontSize="11"/>
                            </Grid>
                        </Border>

                    </Grid>

                    <!-- Stat strip — 8 dense numbers, sits under hero tiles -->
                    <Border Grid.Row="1" Classes="card" Padding="20,14">
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*,*">

                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="label" Text="WINS"/>
                                <TextBlock x:Name="StripWinsText" Classes="strip-value good"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="label" Text="LOSSES"/>
                                <TextBlock x:Name="StripLossesText" Classes="strip-value danger"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="label" Text="KILLS"/>
                                <TextBlock x:Name="StripKillsText" Classes="strip-value"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Classes="label" Text="DEATHS"/>
                                <TextBlock x:Name="StripDeathsText" Classes="strip-value"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Classes="label" Text="ASSISTS"/>
                                <TextBlock x:Name="StripAssistsText" Classes="strip-value"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5">
                                <TextBlock Classes="label" Text="FLAWLESS"/>
                                <TextBlock x:Name="StripFlawlessText" Classes="strip-value"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Classes="label" Text="MATCH MVP"/>
                                <TextBlock x:Name="StripMatchMvpText" Classes="strip-value"/>
                            </StackPanel>
                            <StackPanel Grid.Column="7">
                                <TextBlock Classes="label" Text="TEAM MVP"/>
                                <TextBlock x:Name="StripTeamMvpText" Classes="strip-value"/>
                            </StackPanel>

                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- ═════════════════════════════════════════════════════════════
                 RESULTS — donut + breakdown.
                 The right card uses TWO separate child containers in the
                 Grid, with a fixed gap column between them, to keep label
                 columns from bleeding into each other (the bug from the
                 previous build).
                 ═════════════════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="RESULTS" Margin="0,12,0,12"/>
            <Grid ColumnDefinitions="320,*" Margin="0,0,0,16">

                <!-- Donut + counts -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,8,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <ctl:DonutChart Grid.Column="0"
                                        x:Name="WinDonut"
                                        Width="140" Height="140"
                                        VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="20,0,0,0">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         Fill="{DynamicResource Good}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Classes="label" Text="WINS"/>
                                    <TextBlock x:Name="WinsCountText"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Fg.Primary}"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         Fill="{DynamicResource Danger}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Classes="label" Text="LOSSES"/>
                                    <TextBlock x:Name="LossesCountText"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Fg.Primary}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Streaks / favourites — left & right columns separated by
                     an explicit gap column so values can't collide with the
                     next column's label. -->
                <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
                    <Grid ColumnDefinitions="*,32,*">

                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Current streak" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="CurrentStreakText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Longest win streak" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="LongestStreakText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Total play time" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="TotalTimeText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Avg match length" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="AvgMatchTimeText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Net win delta" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="NetWinDeltaText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Avg K/D/A" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="AvgKdaText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Favourite map" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="FavMapText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                            <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Favourite weapon" Foreground="{DynamicResource Fg.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="FavWeaponText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                            </Grid>
                        </StackPanel>

                    </Grid>
                </Border>

            </Grid>

            <!-- ═════════════════════════════════════════════════════════════
                 PERFORMANCE — combat list + accuracy/damage bars.
                 ═════════════════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="PERFORMANCE" Margin="0,12,0,12"/>
            <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">

                <Border Grid.Column="0" Classes="card" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="COMBAT (PER MATCH)" Margin="0,0,0,12"/>

                        <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Avg kills" Foreground="{DynamicResource Fg.Secondary}"/>
                            <TextBlock Grid.Column="1" x:Name="AvgKillsText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                        </Grid>
                        <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Avg deaths" Foreground="{DynamicResource Fg.Secondary}"/>
                            <TextBlock Grid.Column="1" x:Name="AvgDeathsText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                        </Grid>
                        <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Avg damage" Foreground="{DynamicResource Fg.Secondary}"/>
                            <TextBlock Grid.Column="1" x:Name="AvgDmgText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                        </Grid>
                        <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Avg heal" Foreground="{DynamicResource Fg.Secondary}"/>
                            <TextBlock Grid.Column="1" x:Name="AvgHealText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                        </Grid>
                        <Grid Classes="stat-row" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Total damage" Foreground="{DynamicResource Fg.Secondary}"/>
                            <TextBlock Grid.Column="1" x:Name="TotalDmgText" FontWeight="SemiBold" Foreground="{DynamicResource Fg.Primary}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="ACCURACY" Margin="0,0,0,12"/>
                        <ctl:BarRow x:Name="WeaponAccBar"  Label="Weapon"  Max="100" Format="{}{0:0.0}%" Margin="0,0,0,8"/>
                        <ctl:BarRow x:Name="AbilityAccBar" Label="Ability" Max="100" Format="{}{0:0.0}%" Margin="0,0,0,16"/>

                        <TextBlock Classes="label" Text="DAMAGE BALANCE" Margin="0,8,0,8"/>
                        <ctl:BarRow x:Name="DamageDealtBar" Label="Dealt / match" Format="{}{0:#,0}" Margin="0,0,0,8"/>
                        <ctl:BarRow x:Name="DamageTakenBar" Label="Taken / match" Format="{}{0:#,0}"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- ═════════════════════════════════════════════════════════════
                 PERSONAL BESTS
                 ═════════════════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="PERSONAL BESTS" Margin="0,12,0,12"/>
            <Border Classes="card" Margin="0,0,0,16">
                <Grid ColumnDefinitions="*,*,*">

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Classes="label" Text="BEST KILLS"/>
                        <TextBlock x:Name="BestKillsText"
                                   FontFamily="{DynamicResource Font.Display}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource Good}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="0" Width="1" HorizontalAlignment="Right"
                            Background="{DynamicResource Border.Subtle}"/>

                    <StackPanel Grid.Column="1" Margin="20,0,12,0">
                        <TextBlock Classes="label" Text="BEST DAMAGE"/>
                        <TextBlock x:Name="BestDamageText"
                                   FontFamily="{DynamicResource Font.Display}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource Good}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right"
                            Background="{DynamicResource Border.Subtle}"/>

                    <StackPanel Grid.Column="2" Margin="20,0,0,0">
                        <TextBlock Classes="label" Text="BEST K/D"/>
                        <TextBlock x:Name="BestKdText"
                                   FontFamily="{DynamicResource Font.Display}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource Good}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
