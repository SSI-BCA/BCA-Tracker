<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BCATracker.UI.Views.LifetimeStatsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Classes="page-title" Text="Lifetime Stats"/>
            <TextBlock x:Name="SubtitleText" Classes="muted" Margin="0,4,0,24"/>

            <!-- Combat -->
            <TextBlock Classes="section-title" Text="COMBAT" Margin="0,0,0,12"/>
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="K/D RATIO"/>
                        <TextBlock x:Name="KdText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="K/D/A RATIO"/>
                        <TextBlock x:Name="KdaText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="AVG KILLS"/>
                        <TextBlock x:Name="AvgKillsText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile">
                    <StackPanel>
                        <TextBlock Classes="label" Text="AVG DEATHS"/>
                        <TextBlock x:Name="AvgDeathsText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Damage / Accuracy -->
            <TextBlock Classes="section-title" Text="DAMAGE &amp; ACCURACY" Margin="0,0,0,12"/>
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="AVG DAMAGE"/>
                        <TextBlock x:Name="AvgDmgText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="TOTAL DAMAGE"/>
                        <TextBlock x:Name="TotalDmgText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="WEAPON ACC."/>
                        <TextBlock x:Name="WeaponAccText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile">
                    <StackPanel>
                        <TextBlock Classes="label" Text="ABILITY ACC."/>
                        <TextBlock x:Name="AbilityAccText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Outcomes -->
            <TextBlock Classes="section-title" Text="OUTCOMES" Margin="0,0,0,12"/>
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="WIN %"/>
                        <TextBlock x:Name="WinPctText" Classes="stat-value good"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="WINS"/>
                        <TextBlock x:Name="WinsText" Classes="stat-value good"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="LOSSES"/>
                        <TextBlock x:Name="LossesText" Classes="stat-value danger"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile">
                    <StackPanel>
                        <TextBlock Classes="label" Text="MATCHES"/>
                        <TextBlock x:Name="MatchesText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Records -->
            <TextBlock Classes="section-title" Text="RECORDS" Margin="0,0,0,12"/>
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="BEST MATCH KILLS"/>
                        <TextBlock x:Name="BestKillsText" Classes="stat-value good"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="BEST MATCH DAMAGE"/>
                        <TextBlock x:Name="BestDamageText" Classes="stat-value good"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="BEST MATCH K/D"/>
                        <TextBlock x:Name="BestKdText" Classes="stat-value good"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile">
                    <StackPanel>
                        <TextBlock Classes="label" Text="LONGEST WIN STREAK"/>
                        <TextBlock x:Name="LongestStreakText" Classes="stat-value good"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Highlights -->
            <TextBlock Classes="section-title" Text="HIGHLIGHTS" Margin="0,0,0,12"/>
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="CURRENT STREAK"/>
                        <TextBlock x:Name="CurrentStreakText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="FLAWLESS MATCHES"/>
                        <TextBlock x:Name="FlawlessText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="MATCH MVP"/>
                        <TextBlock x:Name="MatchMvpText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile">
                    <StackPanel>
                        <TextBlock Classes="label" Text="TEAM MVP"/>
                        <TextBlock x:Name="TeamMvpText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Time -->
            <TextBlock Classes="section-title" Text="TIME" Margin="0,0,0,12"/>
            <UniformGrid Columns="2" Rows="1" Margin="0,0,0,24">
                <Border Classes="card stat-tile" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="TOTAL PLAY TIME"/>
                        <TextBlock x:Name="TotalTimeText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
                <Border Classes="card stat-tile">
                    <StackPanel>
                        <TextBlock Classes="label" Text="AVG MATCH LENGTH"/>
                        <TextBlock x:Name="AvgMatchTimeText" Classes="stat-value"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
