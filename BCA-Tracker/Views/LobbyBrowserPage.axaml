<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:BCATracker.UI.Views"
             x:Class="BCATracker.UI.Views.LobbyBrowserPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="1280" HorizontalAlignment="Stretch">

            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,4">
                <TextBlock Grid.Column="0" Classes="page-title" Text="Lobbies"/>
                <Button Grid.Column="1"
                        x:Name="JoinByIdBtn"
                        Content="Join by ID"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Click="JoinById_Click"/>
                <Button Grid.Column="2"
                        x:Name="RefreshBtn"
                        Content="Refresh"
                        VerticalAlignment="Center"
                        Click="Refresh_Click"/>
            </Grid>
            <TextBlock x:Name="SubtitleText" Classes="muted" Margin="0,4,0,24"
                       Text="Host your own custom lobby or browse open ones."/>

            <!-- ═════════════════════════════════════════════════════════════
                 CONNECTED PLAYERS — shows the live member list for the
                 NetBird lobby network you're currently in.
                   • As HOST: shows everyone enrolled in your lobby's
                     group. The Leave button is hidden (hosts don't
                     "leave" — they stop hosting via the advertise
                     toggle).
                   • As GUEST: shows the same list, with a Leave button.
                 Refreshes every few seconds while visible.
                 ═════════════════════════════════════════════════════════════ -->
            <Border x:Name="ConnectedBanner" Classes="card" Margin="0,0,0,24" IsVisible="False">
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Classes="label"
                                       x:Name="ConnectedHeaderLabel"
                                       Text="CONNECTED TO LOBBY"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="ConnectedLobbyText"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Fg.Primary}"/>
                            <TextBlock x:Name="ConnectedAddressText"
                                       Classes="muted"
                                       FontFamily="Consolas, monospace"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="ConnectedCopyBtn"
                                Content="Copy IP"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Click="ConnectedCopy_Click"/>
                        <Button Grid.Column="2"
                                x:Name="ConnectedLeaveBtn"
                                Content="Leave"
                                Classes="primary"
                                VerticalAlignment="Center"
                                Click="ConnectedLeave_Click"/>
                    </Grid>

                    <!-- Member list. Populated from
                         GET /v1/nb/lobbies/{groupId}/members. -->
                    <TextBlock Classes="label" Text="PLAYERS" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="ConnectedMembersList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" Spacing="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="views:ConnectedMemberRow">
                                <Border Padding="10,6"
                                        Background="{DynamicResource Bg.Surface}"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Fg.Primary}"/>
                                        <Border Grid.Column="1"
                                                Margin="8,0"
                                                Padding="6,2"
                                                CornerRadius="3"
                                                Background="{Binding RoleBackground}"
                                                IsVisible="{Binding HasRoleBadge}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RoleLabel}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding NetBirdIP}"
                                                   FontFamily="Consolas, monospace"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Fg.Secondary}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="ConnectedMembersEmpty"
                               Classes="muted"
                               FontSize="12"
                               Margin="0,4,0,0"
                               IsVisible="False"
                               Text="No other players yet - waiting for someone to join."/>
                </StackPanel>
            </Border>

            <!-- ═════════════════════════════════════════════════════════════
                 MY LOBBY — hosting controls.
                 ═════════════════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="MY LOBBY" Margin="0,0,0,12"/>
            <Border Classes="card" Margin="0,0,0,24">
                <StackPanel>
                    <CheckBox x:Name="LobbyAdvertiseCheck"
                              Content="Advertise my lobby when I'm hosting a BCA custom game"
                              IsCheckedChanged="LobbyAdvertise_Changed"/>

                    <TextBlock Classes="label" Text="LOBBY NAME" Margin="0,16,0,4"/>
                    <TextBox x:Name="LobbyNameBox"
                             Watermark="Leave blank to use '{your handle}'s lobby'"
                             LostFocus="LobbyName_LostFocus"/>

                    <TextBlock Classes="label" Text="STATUS" Margin="0,16,0,4"/>
                    <TextBlock x:Name="HostingStatusText"
                               Classes="muted"
                               FontFamily="Consolas, monospace"
                               Text="(idle)"/>

                    <!-- Advanced: extra controls that most hosts won't touch.
                         Tucked away so the default view stays simple. -->
                    <Expander Header="Advanced" Margin="0,16,0,0">
                        <StackPanel Margin="0,8,0,0">

                            <CheckBox x:Name="LobbyPasswordCheck"
                                      Content="Password-protect this lobby"
                                      IsCheckedChanged="LobbyPasswordCheck_Changed"/>
                            <TextBox x:Name="LobbyPasswordBox"
                                     Margin="0,4,0,0"
                                     PasswordChar="*"
                                     Watermark="Enter a password (4-256 characters)"
                                     IsVisible="False"
                                     LostFocus="LobbyPassword_LostFocus"/>

                            <CheckBox x:Name="LobbyHiddenCheck"
                                      Content="Hide from public list (invite only)"
                                      Margin="0,12,0,0"
                                      IsCheckedChanged="LobbyHidden_Changed"/>
                            <TextBlock Classes="caption" Margin="24,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Only people with the Lobby ID can find your lobby."/>

                            <TextBlock Classes="label" Text="LOBBY ID" Margin="0,16,0,4"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox x:Name="LobbyIdBox"
                                         Grid.Column="0"
                                         IsReadOnly="True"
                                         IsHitTestVisible="False"
                                         Focusable="False"
                                         FontFamily="Consolas, monospace"
                                         Text="(not hosting yet)"/>
                                <Button Grid.Column="1"
                                        x:Name="LobbyIdRevealBtn"
                                        Margin="8,0,0,0"
                                        Content="Reveal"
                                        IsEnabled="False"
                                        Click="LobbyIdReveal_Click"/>
                                <Button Grid.Column="2"
                                        x:Name="LobbyIdCopyBtn"
                                        Margin="8,0,0,0"
                                        Content="Copy"
                                        IsEnabled="False"
                                        Click="LobbyIdCopy_Click"/>
                            </Grid>
                            <TextBlock Classes="caption" Margin="0,4,0,12"
                                       TextWrapping="Wrap"
                                       Text="Share this with friends so they can join. Blurred by default - click Reveal to see it, or Copy to send it directly."/>

                            <CheckBox x:Name="LobbyForceHostCheck"
                                      Content="I am the host (manual override)"
                                      IsCheckedChanged="LobbyForceHost_Changed"/>
                            <TextBlock Classes="caption" Margin="24,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Tick this if you're hosting but the tracker doesn't pick it up automatically."/>

                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- ═════════════════════════════════════════════════════════════
                 AVAILABLE LOBBIES — browser list.
                 ═════════════════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="AVAILABLE LOBBIES" Margin="0,0,0,12"/>

            <Border x:Name="ConnectInfoCard" Classes="card" Margin="0,0,0,16" IsVisible="False">
                <TextBlock Foreground="{DynamicResource Fg.Secondary}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="Click any lobby to get the IP:port to paste into BCA's direct-connect menu."/>
            </Border>

            <ItemsControl x:Name="LobbyList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <TextBlock x:Name="EmptyText"
                       Classes="muted"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       IsVisible="False"
                       Text="No lobbies open right now. Be the first to host one!"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
