<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:BCATracker.UI.Controls"
             x:Class="BCATracker.UI.Views.TrendsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,0,32,32" MaxWidth="1280" HorizontalAlignment="Stretch">
            <TextBlock x:Name="PageTitleText" Classes="page-title" Text="Trends"/>
            <TextBlock x:Name="SubtitleText" Classes="muted" Margin="0,4,0,16"/>

            <!-- Range selector. Buttons are toggle-styled via the .range-btn
                 and .range-btn.active classes (defined in Controls.axaml). -->
            <Border Classes="card" Padding="20,14" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RANGE"
                               Classes="label"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button x:Name="Range10Btn"  Content="Last 10" Click="Range_Click" Tag="10"  Margin="0,0,4,0"/>
                    <Button x:Name="Range25Btn"  Content="Last 25" Click="Range_Click" Tag="25"  Margin="0,0,4,0"/>
                    <Button x:Name="Range50Btn"  Content="Last 50" Click="Range_Click" Tag="50"  Margin="0,0,4,0"/>
                    <Button x:Name="RangeAllBtn" Content="All"     Click="Range_Click" Tag="0"/>
                </StackPanel>
            </Border>

            <!-- Summary strip — five quick numbers for the selected range -->
            <Border Classes="card" Padding="20,14" Margin="0,0,0,16">
                <Grid ColumnDefinitions="*,*,*,*,*">

                    <StackPanel Grid.Column="0">
                        <TextBlock Classes="label" Text="MATCHES"/>
                        <TextBlock x:Name="MatchCountTotal" Classes="strip-value"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="label" Text="WIN %"/>
                        <TextBlock x:Name="WinPctTotal" Classes="strip-value good"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Classes="label" Text="AVG K/D"/>
                        <TextBlock x:Name="AvgKdTotal" Classes="strip-value"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Classes="label" Text="AVG DAMAGE"/>
                        <TextBlock x:Name="AvgDmgTotal" Classes="strip-value"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Classes="label" Text="AVG ACCURACY"/>
                        <TextBlock x:Name="AvgAccTotal" Classes="strip-value"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Featured chart — the big one. Metric pills above the chart
                 let the user switch what's plotted. -->
            <Border Classes="card" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                        <TextBlock Grid.Column="0"
                                   x:Name="FeaturedChartTitle"
                                   Text="K/D RATIO"
                                   Classes="label"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="MetricKdBtn"      Content="K/D"        Click="Metric_Click" Tag="kd"      Margin="0,0,4,0"/>
                            <Button x:Name="MetricAccBtn"     Content="Accuracy"   Click="Metric_Click" Tag="acc"     Margin="0,0,4,0"/>
                            <Button x:Name="MetricDmgBtn"     Content="Damage"     Click="Metric_Click" Tag="dmg"     Margin="0,0,4,0"/>
                            <Button x:Name="MetricWinRateBtn" Content="Win rate"   Click="Metric_Click" Tag="winrate" Margin="0,0,4,0"/>
                            <Button x:Name="MetricDeltaBtn"   Content="Damage Δ"   Click="Metric_Click" Tag="delta"   Margin="0,0,4,0"/>
                            <Button x:Name="MetricAliveBtn"   Content="Time alive" Click="Metric_Click" Tag="alive"/>
                        </StackPanel>
                    </Grid>
                    <ctl:LineChart x:Name="FeaturedChart" Height="320"/>
                </StackPanel>
            </Border>

            <!-- Featured chart is the only chart on this page now.
                 Use the metric pills above it to switch what's plotted;
                 the 3 mini charts that used to sit here were dropped
                 because they duplicated info already reachable via
                 the pills. -->

        </StackPanel>
    </ScrollViewer>
</UserControl>
