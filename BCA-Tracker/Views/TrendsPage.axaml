<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:BCATracker.UI.Controls"
             x:Class="BCATracker.UI.Views.TrendsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Classes="page-title" Text="Trends"/>
            <TextBlock x:Name="SubtitleText"
                       Classes="muted"
                       Margin="0,4,0,16"/>

            <!-- Range selector + summary stats -->
            <Border Classes="card" Padding="20,14" Margin="0,0,0,16">
                <Grid ColumnDefinitions="Auto,*,Auto">

                    <!-- Range buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="RANGE"
                                   Classes="label"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <Button x:Name="Range10Btn"  Content="Last 10" Click="Range_Click" Tag="10"  Margin="0,0,4,0"/>
                        <Button x:Name="Range25Btn"  Content="Last 25" Click="Range_Click" Tag="25"  Margin="0,0,4,0"/>
                        <Button x:Name="Range50Btn"  Content="Last 50" Click="Range_Click" Tag="50"  Margin="0,0,4,0"/>
                        <Button x:Name="RangeAllBtn" Content="All"     Click="Range_Click" Tag="0"/>
                    </StackPanel>

                    <!-- Summary stats for the selected window -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <StackPanel Margin="20,0">
                            <TextBlock Classes="label" Text="WIN %" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="WinPctTotal"
                                       Classes="stat-mid good"
                                       FontSize="18"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                        <StackPanel Margin="20,0">
                            <TextBlock Classes="label" Text="AVG K/D" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="AvgKdTotal"
                                       Classes="stat-mid"
                                       FontSize="18"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                        <StackPanel Margin="20,0">
                            <TextBlock Classes="label" Text="AVG DMG" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="AvgDmgTotal"
                                       Classes="stat-mid"
                                       FontSize="18"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                        <StackPanel Margin="20,0,0,0">
                            <TextBlock Classes="label" Text="MATCHES" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="MatchCountTotal"
                                       Classes="stat-mid"
                                       FontSize="18"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chart grid: 2 columns, 3 rows. -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">

                <Border Grid.Row="0" Grid.Column="0"
                        Classes="card" Padding="20,16" Margin="0,0,8,16">
                    <StackPanel>
                        <TextBlock Classes="label" Text="K/D RATIO"/>
                        <ctl:LineChart x:Name="KdChart" Height="180" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1"
                        Classes="card" Padding="20,16" Margin="8,0,0,16">
                    <StackPanel>
                        <TextBlock Classes="label" Text="WEAPON ACCURACY (%)"/>
                        <ctl:LineChart x:Name="AccChart" Height="180" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0"
                        Classes="card" Padding="20,16" Margin="0,0,8,16">
                    <StackPanel>
                        <TextBlock Classes="label" Text="DAMAGE PER MATCH"/>
                        <ctl:LineChart x:Name="DmgChart" Height="180" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1"
                        Classes="card" Padding="20,16" Margin="8,0,0,16">
                    <StackPanel>
                        <TextBlock Classes="label" Text="WIN RATE — 10-MATCH ROLLING (%)"/>
                        <ctl:LineChart x:Name="WinRateChart" Height="180" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="0"
                        Classes="card" Padding="20,16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="DAMAGE DELTA (DEALT − TAKEN)"/>
                        <ctl:LineChart x:Name="DeltaChart" Height="180" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="1"
                        Classes="card" Padding="20,16" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Classes="label" Text="TIME ALIVE (SECONDS)"/>
                        <ctl:LineChart x:Name="TimeAliveChart" Height="180" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
