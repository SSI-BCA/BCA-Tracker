<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:BCATracker.UI.Controls"
        xmlns:views="clr-namespace:BCATracker.UI.Views"
        x:Class="BCATracker.UI.MainWindow"
        Title="BCA-Tracker"
        Width="1320" Height="860"
        MinWidth="980" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg.Base}">

    <Border Background="{DynamicResource Bg.Base}">
        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource Border.Subtle}"
                    BorderThickness="0,0,0,1">
                <ctl:TopNav x:Name="Nav"/>
            </Border>

            <!-- Update banner — shown only when UpdateChecker reports a
                 newer release on GitHub. Slim, dismissable, doesn't
                 push content around when hidden. -->
            <Border Grid.Row="1"
                    x:Name="UpdateBanner"
                    IsVisible="False"
                    Background="#1F2A5BE0"
                    BorderBrush="#5B8DEF"
                    BorderThickness="0,0,0,1"
                    Padding="20,10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               x:Name="UpdateBannerText"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Fg.Primary}"
                               Text="Update available."/>
                    <Button Grid.Column="1"
                            x:Name="UpdateDownloadBtn"
                            Content="Download &amp; install"
                            Classes="primary"
                            Margin="0,0,8,0"
                            Click="UpdateDownload_Click"/>
                    <Button Grid.Column="2"
                            x:Name="UpdateDismissBtn"
                            Content="Later"
                            Click="UpdateDismiss_Click"/>
                </Grid>
            </Border>

            <ContentControl x:Name="ContentHost"
                            Grid.Row="2"
                            Background="Transparent"/>

            <!-- Status bar -->
            <Border Grid.Row="3"
                    Background="{DynamicResource Bg.Nav}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource Border.Subtle}"
                    Padding="20,7">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{DynamicResource Good}"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText"
                                   Margin="8,0,0,0"
                                   Classes="caption"/>
                    </StackPanel>
                    <TextBlock x:Name="VersionText"
                               Grid.Column="1"
                               Classes="caption"
                               Foreground="{DynamicResource Fg.Disabled}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
