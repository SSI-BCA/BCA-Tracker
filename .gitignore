# ─────────────────────────────────────────────────────────────────────────────
# BCA-Tracker / lobby-backend
# Covers: .NET 10 C# (tracker + Core), Avalonia, Go backend, Inno Setup,
#         bundled NetBird MSI, common editor/OS noise, secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── .NET build outputs ──────────────────────────────────────────────────────
bin/
obj/
publish/
*.user
*.suo
*.userprefs
*.cache
*.pdb
*.dll.config
*.exe.config
*.vsidx
*.lock.json
.vs/
project.lock.json
*.binlog

# Single-file publish output (handled by build-installer.ps1)
publish/

# ── Installer artifacts ─────────────────────────────────────────────────────
installer/dist/
installer/bundle/
# Specifically the bundled NetBird MSI — large, fetched fresh on every build
installer/bundle/netbird_installer.msi
installer/bundle/*.msi
installer/bundle/*.exe

# ── Go backend ──────────────────────────────────────────────────────────────
# Compiled binaries (no extension on Linux/macOS, .exe on Windows)
lobby-backend/lobby-server
lobby-backend/lobby-server.exe
lobby-backend/cmd/lobby-server/lobby-server
lobby-backend/cmd/lobby-server/lobby-server.exe

# Local databases / state
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db

# Go workspace overrides — keep go.mod/go.sum, ignore the local-only workspace file
go.work
go.work.sum

# Test coverage
coverage.out
coverage.html

# ── Secrets and local config ────────────────────────────────────────────────
# Anything that smells like a key or token. Add specific filenames here as
# the repo grows.
*.env
.env
.env.*
!.env.example
secrets.json
secrets/
*.pfx
*.pem
*.key

# NetBird configuration (if you ever shell-source it locally)
netbird.env
nb.env

# ── Logs and runtime data ───────────────────────────────────────────────────
*.log
logs/
diag*.log
journalctl*.log

# AppData-style runtime dirs (in case anyone checks one out by accident)
matches/

# ── IDE / editor noise ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# JetBrains Rider
.idea/
*.sln.iml
*.iml

# ── OS junk ─────────────────────────────────────────────────────────────────
$RECYCLE.BIN/
*.lnk

# ── Misc ────────────────────────────────────────────────────────────────────
# Generated NuGet restore files we don't need in source control
*.nupkg
*.snupkg
nuget.exe

# Inno Setup compiler outputs that aren't already covered above
*.iss.bak

# Local-only test scratch
/scratch/
/tmp/